# Moedim website — environment template.
# Copy to .env.local for local development.
# All values are optional in dev; missing values disable the corresponding
# integration but do not break the build.
#
# Server-only secrets (no NEXT_PUBLIC_ prefix) MUST NEVER appear in client code.
# They are validated via getServerEnv() in lib/env.ts which throws on browser access.

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://www.moedim.ai

# --- Analytics ---
# Plausible cookie-less analytics. Domain only (e.g. "moedim.ai").
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# PostHog (opt-in funnel analytics, gated by cookie banner once shipped in W12).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Vercel Analytics auto-detects on Vercel. No env required.

# --- Error tracking ---
# Sentry browser DSN. Leave empty to disable.
NEXT_PUBLIC_SENTRY_DSN=
# Server-side. Used for source-map upload + alert routing in W12.
SENTRY_ENV=development

# --- Sanity (CMS) ---
# Read-only project metadata, fine to expose to the browser.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01

# Server-only read token (for draft mode / preview). Never expose.
SANITY_API_READ_TOKEN=
# Server-only revalidation webhook secret.
SANITY_WEBHOOK_SECRET=

# --- Supabase (website project, NOT the platform admin DB) ---
# Anon key respects RLS — safe in the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server-only. Bypasses RLS. Used only in trusted API
# routes and Vercel Cron jobs. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=
